[sub_resource type="GDScript" id="GDScript_0080g"]
script/source = "extends Node3D

@onready var camera_3d: Camera3D = $MeshInstance3D/SubViewport/Camera3D
@onready var mirror_plane: MeshInstance3D = $MeshInstance3D
@onready var dummy_cam_pos: Node3D = $MeshInstance3D/DummyCamPos

func _process(delta: float) -> void:
	var player_camera = _get_local_player_camera()
	if not player_camera:
		return

	_update_mirror_transform(player_camera)

func _get_local_player_camera() -> Camera3D:
	var player = get_tree().get_first_node_in_group(\"Player\")
	if player and player.has_node(\"%Camera3D\"):
		return player.get_node(\"%Camera3D\")
	return null

func _update_mirror_transform(player_camera: Camera3D) -> void:
	var plane_point = mirror_plane.global_position
	var player_pos = player_camera.global_position

	var to_player = player_pos - plane_point
	var mirror_cam_pos = plane_point + to_player
	
	camera_3d.global_position = mirror_cam_pos
	
	var look_target = Vector3(player_pos.x, camera_3d.global_position.y, player_pos.z)
	camera_3d.look_at(look_target, Vector3.UP)

func _get_mirror_normal() -> Vector3:
	var global_transform = mirror_plane.global_transform
	return -global_transform.basis.z.normalized()

func _reflect_point_across_plane(point: Vector3, plane_point: Vector3, plane_normal: Vector3) -> Vector3:
	var to_point = point - plane_point
	var distance = to_point.dot(plane_normal)
	return point - plane_normal * (2.0 * distance)

func _reflect_vector_across_plane(vector: Vector3, plane_normal: Vector3) -> Vector3:
	var distance = vector.dot(plane_normal)
	return vector - plane_normal * (2.0 * distance)
"

